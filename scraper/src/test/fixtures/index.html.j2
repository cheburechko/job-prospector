<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<title>Jobs at Acme Corp</title>
</head>
<body>
<main>
  <div class="job-posts">
    <table>
      <tbody>
        {% for job in jobs %}
        <tr class="job-post">
          <td class="cell">
            <a href="{{ base_url }}/careers/jobs/{{ job.id }}">
              <p class="body body--medium">{{ job.title }}</p>
              <p class="body body__secondary body--metadata">{{ job.location }}</p>
            </a>
          </td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
  {% if next_page_url %}
  <button class="pagination__next" onclick="window.location='{{ next_page_url }}'">Next</button>
  {% elif show_disabled_next %}
  <button class="pagination__next" aria-disabled="true">Next</button>
  {% endif %}
</main>
</body>
</html>
