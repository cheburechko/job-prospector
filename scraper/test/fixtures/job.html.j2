<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<title>{{ title }} at Acme Corp</title>
<meta property="og:title" content="{{ title }}">
<meta property="og:description" content="{{ location }}">
</head>
<body>
<main class="job-post">
  <div class="job__header">
    <div class="job__title">
      <h1 class="section-header section-header--large font-primary">{{ title }}</h1>
      <div class="job__location">
        <div>{{ location }}</div>
      </div>
    </div>
  </div>
  <div class="job__description body">
    <p>At Acme Corp, we build innovative solutions that make a difference.</p>
  </div>
</main>
</body>
</html>
